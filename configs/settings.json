      "player_esp": true,
      "loot_esp": true,
      "vehicle_esp": true,
      "distance": 300,
      "glow": true,
      "chams": false
    },
    "building_assist": {
      "enabled": true,
      "fast_edit": true,
      "auto_build": false,
      "edit_prediction": true
    },
    "misc": {
      "no_bloom": true,
      "no_recoil": true,
      "instant_reload": false,
      "speed_multiplier": 1.0
    }
  }
